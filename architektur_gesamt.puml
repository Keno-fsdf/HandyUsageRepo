@startuml
!theme plain
skinparam backgroundColor white
skinparam defaultFontSize 12
skinparam ArrowThickness 2
skinparam RoundCorner 10
skinparam nodesep 18
skinparam ranksep 45
skinparam PackagePadding 14

top to bottom direction

title Gesamtarchitektur: Akkuvorhersage mit TinyML\n

' ============================================================
'  ANDROID APP — UI + Datensammlung + On-Device-Inferenz
' ============================================================
package "Android Smartphone" as phone #E3F2FD {

    package "UI Layer (Kotlin / XML)" as uilayer #BBDEFB {
        [OnboardingActivity\n(4 Slides,\nbeim ersten Start)] as onboarding
        [MainActivity\n(BottomNavigation)] as mainact
        [LiveFragment\n(Vorhersage +\n10 Live-Sensoren)] as live
        [AlgorithmFragment\n(Conv1D-Visualisierung +\nModelDeepDive-Sheet)] as algo
        [AccuracyFragment\n(3-Wege-Score +\nVerlauf)] as accuracy
        [SettingsActivity\n(Permissions, CSV-Export,\nOnboarding-Replay,\nBasis-Daten-Reset,\nTrain-Own-Anleitung)] as settings
    }

    [DataCollectorService\n(Foreground, alle 30s)\n---\n10 Feature-Extraktoren\n+ Notification mit\nConfidence-Pille] as service #C8E6C9

    [BootReceiver\n(Auto-Restart nach\nReboot / Wegwischen)] as boot #C8E6C9

    [BatteryPredictor\n---\nTFLite Interpreter (INT8)\nStandardScaler\nRingPuffer w=10] as inferenz #FFF9C4

    [AccuracyComputer\n---\neigenes Modell vs\nGoogle-API vs\nLineare Baseline] as accComputer #FFF9C4

    [ConfidenceLevel\n(buffer + battery\nbasiert: rot/gelb/grün)] as confidence #FFF9C4

    [Android System APIs\n---\nBatteryManager | PowerManager\nUsageStatsManager\nConnectivityManager\n/sys/.../cpufreq] as apis #E0E0E0

    database "App Storage" as storage {
        [battery_data.csv\n(eigene Sammlung)] as csv_own
        [assets/sample_data.csv\n(Basis-Daten,\nautom. geladen)] as csv_basis
        [assets/battery_model.tflite\n(14,4 KB INT8)] as tflite_app
    }
}

' ============================================================
'  PYTHON PIPELINE — Training + TFLite-Export
' ============================================================
package "Entwicklungsrechner (run_pipeline.py)" as pc #FFF3E0 {

    [Phase 1: Datenvorbereitung\n(prepare_data.py)\n---\nCSV laden | Entlade-Segmente\nSliding-Window (w=10)\nSegment-Level-Split\nStandardScaler fit] as p1 #FFCCBC

    [Phase 2: Modelltraining\n(train_model.py)\n---\nConv1D + Dense\nAdam + MSE\nEarlyStopping] as p2 #FFCCBC

    [Phase 3: TFLite-Konvertierung\n(convert_tflite.py)\n---\nINT8-Quantisierung\nValidierung\nGröße / Latenz prüfen] as p3 #FFCCBC

    database "Dateisystem" as fs {
        [data/ Rohdaten + Splits] as fdata
        [models/ *.keras, *.tflite] as fmodel
        [reports/ Plots, Metriken] as freports
    }
}

' ============================================================
'  Verbindungen App (intern)
' ============================================================
onboarding --> mainact : nach Abschluss
mainact --> live
mainact --> algo
mainact --> accuracy
mainact --> settings : Zahnrad-Icon
settings --> service : Start / Stopp
boot --> service : nach Reboot
service --> apis : liest Sensoren
service --> csv_own : schreibt CSV
service --> inferenz : aktuelle Features
inferenz --> live : Vorhersage
inferenz --> service : für Notification
confidence --> live : Verlässlichkeits-Badge
confidence --> service : Pille in Notification
tflite_app --> inferenz : Modell laden
csv_basis --> accComputer : Erst-Vergleich\n(Basis-Daten)
csv_own --> accComputer : Verlauf
accComputer --> accuracy : 3-Wege-Score

' ============================================================
'  Verbindungen PC (intern)
' ============================================================
p1 --> p2 : npz-Splits
p2 --> p3 : .keras-Modell
p1 ..> fdata : speichert
p2 ..> fmodel
p3 ..> fmodel

' ============================================================
'  Zwischen den Systemen
' ============================================================
csv_own -[#2196F3,bold,dashed]down-> fdata : **CSV Export**\n(via Share Intent)
fmodel -[#4CAF50,bold,dashed]up-> tflite_app : **.tflite zurück**\n(in assets/ einbetten)

' ============================================================
'  LEGENDE
' ============================================================
legend bottom right
  |= Farbe |= Bedeutung |
  |<#E3F2FD> | Android Smartphone |
  |<#FFF3E0> | Entwicklungsrechner |
  |<#BBDEFB> | UI-Komponenten |
  |<#C8E6C9> | Datensammlung / Service |
  |<#FFF9C4> | On-Device-Inferenz |
  |<#FFCCBC> | Pipeline-Phasen |
  |<#2196F3> | Datenfluss (CSV) |
  |<#4CAF50> | Modell-Deployment |
endlegend

@enduml
