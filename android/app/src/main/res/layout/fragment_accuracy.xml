<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/screen_bg"
    android:padding="20dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/acc_title"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="@color/prediction_text"
            android:layout_marginBottom="6dp" />

        <TextView
            android:id="@+id/accSubtitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text=""
            android:textSize="12sp"
            android:textColor="@color/sensor_card_label"
            android:layout_marginBottom="18dp" />

        <!-- Empty State -->
        <TextView
            android:id="@+id/accEmptyText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_card"
            android:padding="20dp"
            android:gravity="center"
            android:lineSpacingExtra="3dp"
            android:text="@string/acc_no_data"
            android:textColor="@color/sensor_card_label"
            android:textSize="14sp"
            android:visibility="visible" />

        <!-- Result Rows -->
        <LinearLayout
            android:id="@+id/accResultsContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">

            <!-- Row: Eigenes Modell -->
            <LinearLayout
                android:id="@+id/accRowOwn"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_winner"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="16dp"
                android:layout_marginBottom="10dp">

                <TextView
                    android:id="@+id/accRankOwn"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🥇"
                    android:textSize="22sp" />

                <TextView
                    android:id="@+id/accLabelOwn"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:layout_weight="1"
                    android:text=""
                    android:textColor="@color/prediction_text"
                    android:textSize="15sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/accValueOwn"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="—"
                    android:textColor="@color/prediction_text"
                    android:textSize="14sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- Row: Google -->
            <LinearLayout
                android:id="@+id/accRowGoogle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_runner"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="16dp"
                android:layout_marginBottom="10dp">

                <TextView
                    android:id="@+id/accRankGoogle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🥈"
                    android:textSize="22sp" />

                <TextView
                    android:id="@+id/accLabelGoogle"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:layout_weight="1"
                    android:text=""
                    android:textColor="@color/sensor_card_value"
                    android:textSize="15sp" />

                <TextView
                    android:id="@+id/accValueGoogle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="—"
                    android:textColor="@color/sensor_card_value"
                    android:textSize="14sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- Row: Linear -->
            <LinearLayout
                android:id="@+id/accRowLinear"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_runner"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="16dp">

                <TextView
                    android:id="@+id/accRankLinear"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🥉"
                    android:textSize="22sp" />

                <TextView
                    android:id="@+id/accLabelLinear"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:layout_weight="1"
                    android:text=""
                    android:textColor="@color/sensor_card_value"
                    android:textSize="15sp" />

                <TextView
                    android:id="@+id/accValueLinear"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="—"
                    android:textColor="@color/sensor_card_value"
                    android:textSize="14sp"
                    android:textStyle="bold" />
            </LinearLayout>

        </LinearLayout>
    </LinearLayout>
</ScrollView>
