<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/screen_bg"
    android:padding="20dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Header -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/alg_title"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="@color/prediction_text" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="@string/alg_subtitle"
            android:textSize="13sp"
            android:textColor="@color/sensor_card_label" />

        <!-- ============================================== -->
        <!-- USP-Pills (prominent oben, gleich beim Oeffnen) -->
        <!-- ============================================== -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:background="@drawable/bg_prediction"
            android:orientation="horizontal"
            android:padding="14dp"
            android:weightSum="3">

            <!-- Pill 1: offline -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🛡"
                    android:textSize="28sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="@string/alg_usp_pill_offline_head"
                    android:textColor="@color/prediction_text"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/alg_usp_pill_offline_sub"
                    android:textColor="@color/prediction_subtext"
                    android:textSize="10sp" />
            </LinearLayout>

            <!-- Trennstrich -->
            <View
                android:layout_width="1dp"
                android:layout_height="match_parent"
                android:layout_marginVertical="4dp"
                android:background="@color/card_outline" />

            <!-- Pill 2: 14,4 KB -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📦"
                    android:textSize="28sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="@string/alg_usp_pill_size_head"
                    android:textColor="@color/prediction_text"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/alg_usp_pill_size_sub"
                    android:textColor="@color/prediction_subtext"
                    android:textSize="10sp" />
            </LinearLayout>

            <!-- Trennstrich -->
            <View
                android:layout_width="1dp"
                android:layout_height="match_parent"
                android:layout_marginVertical="4dp"
                android:background="@color/card_outline" />

            <!-- Pill 3: universal -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🌍"
                    android:textSize="28sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="@string/alg_usp_pill_universal_head"
                    android:textColor="@color/prediction_text"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/alg_usp_pill_universal_sub"
                    android:textColor="@color/prediction_subtext"
                    android:textSize="10sp" />
            </LinearLayout>
        </LinearLayout>

        <!-- ============================================== -->
        <!-- HERO 1: Animierte Datenfluss-Visualisierung    -->
        <!-- ============================================== -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:background="@drawable/bg_card"
            android:orientation="vertical"
            android:padding="14dp">

            <com.batterypredictor.datacollector.DataflowView
                android:layout_width="match_parent"
                android:layout_height="180dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:gravity="center"
                android:text="@string/alg_flow_caption"
                android:textColor="@color/sensor_card_label"
                android:textSize="12sp" />
        </LinearLayout>

        <!-- ============================================== -->
        <!-- HERO 2 (war HERO 3): Modell-Architektur         -->
        <!-- ============================================== -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="22dp"
            android:layout_marginBottom="10dp"
            android:text="@string/alg_arch_section"
            android:textAllCaps="true"
            android:textColor="@color/settings_section_label"
            android:textSize="12sp"
            android:textStyle="bold"
            android:letterSpacing="0.08" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_card"
            android:orientation="vertical"
            android:padding="14dp">

            <com.batterypredictor.datacollector.ConvLayerView
                android:layout_width="match_parent"
                android:layout_height="340dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:gravity="center"
                android:lineSpacingExtra="2dp"
                android:text="@string/alg_arch_caption"
                android:textColor="@color/sensor_card_label"
                android:textSize="12sp" />
        </LinearLayout>

        <!-- ============================================== -->
        <!-- HERO 3 (war HERO 2): Live-Akku-Verlauf          -->
        <!-- ============================================== -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="22dp"
            android:layout_marginBottom="10dp"
            android:text="@string/alg_chart_section"
            android:textAllCaps="true"
            android:textColor="@color/settings_section_label"
            android:textSize="12sp"
            android:textStyle="bold"
            android:letterSpacing="0.08" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_card"
            android:orientation="vertical"
            android:padding="14dp">

            <com.batterypredictor.datacollector.BatteryHistoryChart
                android:id="@+id/algBatteryChart"
                android:layout_width="match_parent"
                android:layout_height="160dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:gravity="center"
                android:text="@string/alg_chart_caption"
                android:textColor="@color/sensor_card_label"
                android:textSize="12sp" />
        </LinearLayout>

        <!-- ============================================== -->
        <!-- 4 Schritte als Detail-Erklaerung               -->
        <!-- ============================================== -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="10dp"
            android:text="@string/alg_steps_section"
            android:textAllCaps="true"
            android:textColor="@color/settings_section_label"
            android:textSize="12sp"
            android:textStyle="bold"
            android:letterSpacing="0.08" />

        <!-- Schritt 1 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_card"
            android:orientation="horizontal"
            android:padding="16dp">

            <TextView
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:background="@drawable/bg_confidence_high"
                android:gravity="center"
                android:text="1"
                android:textColor="@color/prediction_text"
                android:textSize="18sp"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="14dp"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/alg_step1_title"
                    android:textColor="@color/prediction_text"
                    android:textSize="15sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:lineSpacingExtra="2dp"
                    android:text="@string/alg_step1_body"
                    android:textColor="@color/sensor_card_label"
                    android:textSize="13sp" />
            </LinearLayout>
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginVertical="6dp"
            android:text="↓"
            android:textSize="18sp"
            android:textColor="@color/sensor_card_label" />

        <!-- Schritt 2 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_card"
            android:orientation="horizontal"
            android:padding="16dp">

            <TextView
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:background="@drawable/bg_confidence_high"
                android:gravity="center"
                android:text="2"
                android:textColor="@color/prediction_text"
                android:textSize="18sp"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="14dp"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/alg_step2_title"
                    android:textColor="@color/prediction_text"
                    android:textSize="15sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:lineSpacingExtra="2dp"
                    android:text="@string/alg_step2_body"
                    android:textColor="@color/sensor_card_label"
                    android:textSize="13sp" />
            </LinearLayout>
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginVertical="6dp"
            android:text="↓"
            android:textSize="18sp"
            android:textColor="@color/sensor_card_label" />

        <!-- Schritt 3 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_card"
            android:orientation="horizontal"
            android:padding="16dp">

            <TextView
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:background="@drawable/bg_confidence_high"
                android:gravity="center"
                android:text="3"
                android:textColor="@color/prediction_text"
                android:textSize="18sp"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="14dp"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/alg_step3_title"
                    android:textColor="@color/prediction_text"
                    android:textSize="15sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:lineSpacingExtra="2dp"
                    android:text="@string/alg_step3_body"
                    android:textColor="@color/sensor_card_label"
                    android:textSize="13sp" />
            </LinearLayout>
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginVertical="6dp"
            android:text="↓"
            android:textSize="18sp"
            android:textColor="@color/sensor_card_label" />

        <!-- Schritt 4 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_prediction"
            android:orientation="horizontal"
            android:padding="16dp">

            <TextView
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:background="@drawable/bg_confidence_high"
                android:gravity="center"
                android:text="4"
                android:textColor="@color/prediction_text"
                android:textSize="18sp"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="14dp"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/alg_step4_title"
                    android:textColor="@color/prediction_text"
                    android:textSize="15sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:lineSpacingExtra="2dp"
                    android:text="@string/alg_step4_body"
                    android:textColor="@color/prediction_subtext"
                    android:textSize="13sp" />
            </LinearLayout>
        </LinearLayout>

        <!-- Bottom-Padding fuer Komfort beim Scrollen -->
        <View
            android:layout_width="match_parent"
            android:layout_height="24dp" />

    </LinearLayout>
</ScrollView>
