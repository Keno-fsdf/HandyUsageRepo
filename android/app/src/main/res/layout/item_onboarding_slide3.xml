<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="32dp"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_horizontal"
        android:orientation="vertical">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="⚡"
            android:textSize="56sp"
            android:layout_marginTop="20dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:gravity="center"
            android:text="@string/onb_slide3_title"
            android:textSize="26sp"
            android:textStyle="bold"
            android:textColor="@color/prediction_text" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:gravity="center"
            android:lineSpacingExtra="4dp"
            android:text="@string/onb_slide3_body"
            android:textSize="15sp"
            android:textColor="@color/sensor_card_label" />

        <!-- Modell-Groessen-Vergleich (der Wow-Moment) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="36dp"
            android:orientation="vertical"
            android:background="@drawable/bg_card"
            android:padding="18dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/onb_size_title"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="@color/settings_section_label"
                android:layout_marginBottom="14dp" />

            <!-- Ours: 14,4 KB -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/onb_size_ours"
                android:textSize="13sp"
                android:textColor="@color/prediction_text"
                android:textStyle="bold" />
            <View
                android:layout_width="20dp"
                android:layout_height="10dp"
                android:layout_marginTop="4dp"
                android:layout_marginBottom="14dp"
                android:background="@color/brand_primary" />

            <!-- Voice memo: ~80 KB -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/onb_size_voicememo"
                android:textSize="13sp"
                android:textColor="@color/sensor_card_label" />
            <View
                android:layout_width="100dp"
                android:layout_height="10dp"
                android:layout_marginTop="4dp"
                android:layout_marginBottom="14dp"
                android:background="@color/sensor_bar_inactive" />

            <!-- LLM: ~5 GB -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/onb_size_llm"
                android:textSize="13sp"
                android:textColor="@color/sensor_card_label" />
            <View
                android:layout_width="match_parent"
                android:layout_height="10dp"
                android:layout_marginTop="4dp"
                android:background="@color/sensor_card_label" />
        </LinearLayout>

    </LinearLayout>
</ScrollView>
