<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/screen_bg"
    android:padding="20dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Hauptvorhersage-Karte -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_prediction"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:padding="28dp">

            <TextView
                android:id="@+id/livePredictionLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/live_prediction_label"
                android:textColor="@color/prediction_subtext"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textAllCaps="true"
                android:letterSpacing="0.08" />

            <TextView
                android:id="@+id/livePredictionText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="—"
                android:textColor="@color/prediction_text"
                android:textSize="44sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/livePredictionDetail"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text=""
                android:textColor="@color/prediction_subtext"
                android:textSize="13sp" />

            <com.batterypredictor.datacollector.ConfidenceBadge
                android:id="@+id/liveConfidenceBadge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:visibility="invisible" />

            <TextView
                android:id="@+id/liveBasisBadge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="@string/basis_badge"
                android:textColor="@color/sensor_card_label"
                android:textSize="10sp"
                android:textStyle="italic"
                android:visibility="gone" />
        </LinearLayout>

        <!-- Sensor-Sektion -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="10dp"
            android:text="@string/live_sensors_label"
            android:textAllCaps="true"
            android:textColor="@color/settings_section_label"
            android:textSize="12sp"
            android:textStyle="bold"
            android:letterSpacing="0.08" />

        <LinearLayout
            android:id="@+id/liveSensorsContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical" />

    </LinearLayout>
</ScrollView>
