<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/screen_bg"
    android:orientation="vertical">

    <!-- Toolbar mit Zurueck-Button -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#FFFFFF"
        android:elevation="2dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="12dp">

        <Button
            android:id="@+id/btnSettingsBack"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="←"
            android:textSize="22sp"
            android:minWidth="44dp"
            android:padding="0dp"
            style="@style/Widget.Material3.Button.TextButton" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:text="@string/settings_title"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="@color/prediction_text" />
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:padding="20dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- ============================================== -->
            <!-- Sektion: Datensammlung                          -->
            <!-- ============================================== -->
            <TextView
                style="@style/SettingsSection"
                android:text="@string/settings_collection_section" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_card"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:id="@+id/settingsStatusText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Service ist gestoppt"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="@color/prediction_text" />

                <TextView
                    android:id="@+id/settingsCountText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="0 Datenpunkte gesammelt"
                    android:textSize="13sp"
                    android:textColor="@color/sensor_card_label" />

                <TextView
                    android:id="@+id/settingsPermissionText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Nutzungsdatenzugriff: pruefen…"
                    android:textSize="13sp"
                    android:textColor="@color/sensor_card_label" />

                <Button
                    android:id="@+id/btnSettingsStart"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="@string/settings_start"
                    android:textAllCaps="false"
                    android:backgroundTint="@color/brand_primary" />

                <Button
                    android:id="@+id/btnSettingsStop"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="@string/settings_stop"
                    android:textAllCaps="false"
                    style="@style/Widget.Material3.Button.OutlinedButton" />

                <Button
                    android:id="@+id/btnSettingsRefresh"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="@string/settings_refresh"
                    android:textAllCaps="false"
                    style="@style/Widget.Material3.Button.TextButton" />
            </LinearLayout>

            <!-- ============================================== -->
            <!-- Sektion: Berechtigungen                         -->
            <!-- ============================================== -->
            <TextView
                style="@style/SettingsSection"
                android:text="Berechtigungen" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_card"
                android:orientation="vertical"
                android:padding="16dp">

                <Button
                    android:id="@+id/btnSettingsUsageStats"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/settings_usage_stats"
                    android:textAllCaps="false"
                    style="@style/Widget.Material3.Button.OutlinedButton" />

                <Button
                    android:id="@+id/btnSettingsBatteryOpt"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="@string/settings_battery_opt"
                    android:textAllCaps="false"
                    style="@style/Widget.Material3.Button.OutlinedButton" />
            </LinearLayout>

            <!-- ============================================== -->
            <!-- Sektion: Modell                                 -->
            <!-- ============================================== -->
            <TextView
                style="@style/SettingsSection"
                android:text="@string/settings_model_section" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_card"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/settings_model_size"
                    android:textSize="14sp"
                    android:textColor="@color/prediction_text"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="@string/settings_model_inference"
                    android:textSize="13sp"
                    android:textColor="@color/sensor_card_label" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="@string/settings_model_features"
                    android:textSize="13sp"
                    android:textColor="@color/sensor_card_label" />
            </LinearLayout>

            <!-- ============================================== -->
            <!-- Sektion: Daten exportieren                      -->
            <!-- ============================================== -->
            <TextView
                style="@style/SettingsSection"
                android:text="Daten" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_card"
                android:orientation="vertical"
                android:padding="16dp">

                <Button
                    android:id="@+id/btnSettingsExport"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/settings_export"
                    android:textAllCaps="false"
                    android:backgroundTint="@color/brand_accent" />
            </LinearLayout>

            <!-- ============================================== -->
            <!-- Sektion: Onboarding wiederholen                 -->
            <!-- ============================================== -->
            <TextView
                style="@style/SettingsSection"
                android:text="@string/settings_onboarding_section" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_card"
                android:orientation="vertical"
                android:padding="16dp">

                <Button
                    android:id="@+id/btnSettingsShowOnboarding"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/settings_show_onboarding"
                    android:textAllCaps="false"
                    style="@style/Widget.Material3.Button.OutlinedButton" />
            </LinearLayout>

            <!-- ============================================== -->
            <!-- Sektion: Ueber die App                          -->
            <!-- ============================================== -->
            <TextView
                style="@style/SettingsSection"
                android:text="@string/settings_about_section" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="32dp"
                android:background="@drawable/bg_card"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/settings_about_text"
                    android:textSize="13sp"
                    android:lineSpacingExtra="3dp"
                    android:textColor="@color/sensor_card_label" />
            </LinearLayout>

        </LinearLayout>
    </ScrollView>
</LinearLayout>
