<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@color/screen_bg"
    android:orientation="vertical">

    <!-- Drag-Indikator (kleiner grauer Strich, Material-Standard) -->
    <View
        android:layout_width="36dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="10dp"
        android:layout_marginBottom="6dp"
        android:background="@color/card_outline" />

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="6dp"
        android:paddingBottom="6dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/deepdive_title"
            android:textColor="@color/prediction_text"
            android:textSize="20sp"
            android:textStyle="bold" />

        <Button
            android:id="@+id/deepdiveClose"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="✕"
            android:textSize="18sp"
            android:minWidth="44dp"
            android:padding="0dp"
            style="@style/Widget.Material3.Button.TextButton" />
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="20dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Section: TinyML -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/deepdive_tinyml_title"
                android:textColor="@color/prediction_text"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:lineSpacingExtra="3dp"
                android:text="@string/deepdive_tinyml_body"
                android:textColor="@color/sensor_card_value"
                android:textSize="14sp" />

            <!-- Section: Architektur -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="22dp"
                android:text="@string/deepdive_arch_title"
                android:textColor="@color/prediction_text"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:lineSpacingExtra="3dp"
                android:text="@string/deepdive_arch_body"
                android:textColor="@color/sensor_card_value"
                android:textSize="14sp" />

            <!-- Section: Training -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="22dp"
                android:text="@string/deepdive_training_title"
                android:textColor="@color/prediction_text"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:lineSpacingExtra="3dp"
                android:text="@string/deepdive_training_body"
                android:textColor="@color/sensor_card_value"
                android:textSize="14sp" />

            <!-- Section: Quantisierung -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="22dp"
                android:text="@string/deepdive_quant_title"
                android:textColor="@color/prediction_text"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:lineSpacingExtra="3dp"
                android:text="@string/deepdive_quant_body"
                android:textColor="@color/sensor_card_value"
                android:textSize="14sp" />

            <!-- Section: Features -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="22dp"
                android:text="@string/deepdive_features_title"
                android:textColor="@color/prediction_text"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:layout_marginBottom="32dp"
                android:lineSpacingExtra="4dp"
                android:text="@string/deepdive_features_body"
                android:textColor="@color/sensor_card_value"
                android:textSize="14sp" />

        </LinearLayout>
    </ScrollView>

</LinearLayout>
