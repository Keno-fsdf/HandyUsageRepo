<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="24dp"
    android:background="#FAFAFA">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal">

        <!-- Titel -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🔋 Battery Data Collector"
            android:textSize="22sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Sammelt alle 5 min Akkudaten für TinyML Training"
            android:textSize="13sp"
            android:textColor="#666"
            android:layout_marginBottom="24dp" />

        <!-- Status -->
        <TextView
            android:id="@+id/statusText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Status: Nicht gestartet"
            android:textSize="16sp"
            android:textStyle="bold"
            android:padding="12dp"
            android:background="#E3F2FD"
            android:layout_marginBottom="16dp" />

        <TextView
            android:id="@+id/countText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Gesammelte Datenpunkte: 0"
            android:textSize="15sp"
            android:layout_marginBottom="20dp" />

        <!-- Buttons -->
        <Button
            android:id="@+id/btnStart"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="▶  Datensammlung starten"
            android:textAllCaps="false"
            android:layout_marginBottom="8dp" />

        <Button
            android:id="@+id/btnStop"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="⏹  Datensammlung stoppen"
            android:textAllCaps="false"
            android:backgroundTint="#E57373"
            android:layout_marginBottom="24dp" />

        <!-- Permissions -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Berechtigungen"
            android:textSize="15sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <Button
            android:id="@+id/btnUsageStats"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="📱  Nutzungsdatenzugriff aktivieren"
            android:textAllCaps="false"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_marginBottom="8dp" />

        <Button
            android:id="@+id/btnBatteryOptimize"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🔋  Batterie-Optimierung deaktivieren"
            android:textAllCaps="false"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_marginBottom="24dp" />

        <!-- Export -->
        <Button
            android:id="@+id/btnExport"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="📤  CSV exportieren / teilen"
            android:textAllCaps="false"
            android:backgroundTint="#4CAF50"
            android:layout_marginBottom="24dp" />

        <!-- Daten-Vorschau -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Letzte Messungen:"
            android:textSize="14sp"
            android:textStyle="bold"
            android:layout_marginBottom="4dp" />

        <TextView
            android:id="@+id/dataPreview"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Keine Daten vorhanden"
            android:textSize="10sp"
            android:fontFamily="monospace"
            android:padding="12dp"
            android:background="#ECEFF1"
            android:layout_marginBottom="16dp" />

    </LinearLayout>
</ScrollView>
